{
  "compilerOptions": {
    "types": ["node", "express"],
    "target": "esnext",
    "module": "nodenext",
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "#app/*": ["./src/app/*"],
      "#configs": ["./src/configs"],
      "#configs/*": ["./src/configs/*"],
      "#entities/*": ["./src/entities/*"],
      "#modules/*": ["./src/modules/*"],
      "#platforms/*": ["./src/platforms/*"],
      "#utils/*": ["./src/utils/*"]
    },
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "importHelpers": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noImplicitReturns": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  }
}
